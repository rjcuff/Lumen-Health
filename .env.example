# ── AI Provider ───────────────────────────────────────────────────────────────
# Pick one. You can also configure this interactively with: lumen setup

# Anthropic Claude (best quality) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI or any compatible endpoint
OPENAI_API_KEY=
LUMEN_BASE_URL=          # e.g. https://api.openai.com/v1 or http://localhost:11434/v1

# Override provider/model at runtime
LUMEN_PROVIDER=          # anthropic | openai | ollama
LUMEN_MODEL=             # e.g. claude-sonnet-4-20250514 | gpt-4o | llama3.1

# ── WHOOP ─────────────────────────────────────────────────────────────────────
# Get credentials at https://developer.whoop.com/
# Set redirect URI in your app to: http://localhost:8492/callback
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# ── Garmin ────────────────────────────────────────────────────────────────────
# Garmin uses basic auth — credentials are stored locally after lumen link garmin
# No env vars needed; configure interactively.
